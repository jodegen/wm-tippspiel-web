# nginx-Reverse-Proxy für das WM-Tippspiel-Frontend (wm.xenoria.de).
# Das Next.js-Frontend läuft lokal via `next start` auf 127.0.0.1:3000.
# Nach Anpassung: /etc/nginx/sites-available/ ablegen, verlinken, `nginx -t && systemctl reload nginx`.

# --- Frontend: wm.xenoria.de -------------------------------------------------
server {
    listen 80;
    listen [::]:80;
    server_name wm.xenoria.de;
    # HTTP -> HTTPS (Zertifikate z. B. via certbot --nginx)
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name wm.xenoria.de;

    # ssl_certificate     /etc/letsencrypt/live/wm.xenoria.de/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/wm.xenoria.de/privkey.pem;

    # Statische Next.js-Assets direkt mit langem Cache ausliefern.
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_cache_valid 200 60m;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
        proxy_read_timeout 60s;
    }
}

# --- Backend-API: api.wm.xenoria.de (separat / vom Backend verwaltet) --------
# WICHTIG: Da das Frontend (wm.xenoria.de) das /live-Polling clientseitig macht,
# MUSS die API CORS für den Frontend-Origin erlauben. Beispiel-Header
# (idealerweise vom Backend selbst gesetzt; alternativ hier am Proxy):
#
# add_header Access-Control-Allow-Origin  "https://wm.xenoria.de" always;
# add_header Access-Control-Allow-Methods "GET, OPTIONS" always;
# add_header Vary "Origin" always;
# if ($request_method = OPTIONS) { return 204; }
